  "dependencies": {
    "@qvac/sdk": "^0.13.5",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1"
  }
