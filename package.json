{
  "name": "offline-ai-image-generator",
  "version": "1.0.0",
  "description": "Minimalistic local image generator UI and server",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "build:css": "tailwindcss -i src/input.css -o public/style.css --minify",
    "watch:css": "tailwindcss -i src/input.css -o public/style.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"node server.js\""
  },
